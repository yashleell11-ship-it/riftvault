# Local dev (SQLite):
DATABASE_URL="file:./dev.db"
# Production (Postgres — change prisma/schema.prisma provider to "postgresql"):
# DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"
AUTH_SECRET="riftvault-dev-secret-change-in-production"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Reserve daily reset timezone (IANA, default Asia/Dubai = GMT+4)
RESERVE_RESET_TIMEZONE="Asia/Dubai"

# Default platform currency: ETH | USDT | BNB | BTC
NEXT_PUBLIC_DEFAULT_CURRENCY="USDT"

# Optional — real email delivery (verification, password reset, etc.)
# Option A — Gmail / any SMTP (recommended for local testing to your real inbox)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your.email@gmail.com"
SMTP_PASS="your-gmail-app-password"
EMAIL_FROM="RiftVault <your.email@gmail.com>"

# Option B — Resend API (good for production)
# RESEND_API_KEY="re_..."
# EMAIL_FROM="RiftVault <onboarding@resend.dev>"

# Wallet deposits
# ALLOW_DEMO_DEPOSITS="true"          # allow self-credit in production (dev/testing only)
ENABLE_UNIQUE_DEPOSIT_ADDRESSES="true"
# HD mnemonic for unique per-user deposit addresses (NEVER commit real mnemonic)
DEPOSIT_MNEMONIC="word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12"

# Blockchain (Phase 12+)
NEXT_PUBLIC_CHAIN_ID=11155111
NEXT_PUBLIC_RPC_URL="https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY"
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=""

# Contracts (Phase 13+)
NEXT_PUBLIC_NFT_CONTRACT_ADDRESS=""
NEXT_PUBLIC_MARKETPLACE_CONTRACT_ADDRESS=""
DEPLOYER_PRIVATE_KEY=""
NEXT_PUBLIC_BSC_RPC_URL=""

# Platform token (Phase 15+)
# RVLT ERC-20 testnet address — leave blank to use off-chain ledger only
NEXT_PUBLIC_RVLT_TOKEN_ADDRESS=""

# Post-Claude (Phases 24–29)
# White-label tenant slug (must exist in Tenant table)
NEXT_PUBLIC_TENANT_SLUG="riftvault"

# Production hardening (H2) — cron protection
# CRON_SECRET=""

# ─── USDT BEP20 payments (self-hosted) ─────────────────────────────────────────
# Receiving wallet — replace with Ledger address later without code changes
RECEIVING_WALLET="0x0000000000000000000000000000000000000000"
BSC_RPC_URL="https://bsc-dataseed.binance.org"
BSC_CHAIN_ID="56"
# BSC_USDT_CONTRACT="0x55d398326f99059fF775485246999027B3197955"
PAYMENT_CONFIRMATIONS="12"
PAYMENT_ORDER_EXPIRY_MINUTES="60"
PAYMENT_LISTENER_POLL_MS="15000"
PAYMENT_LISTENER_LOOKBACK_BLOCKS="2000"
# See docs/USDT_PAYMENTS.md for full setup and testing guide

# Local payment listener (npm run payments:listen) — copy to .env.payments.local
# Vercel encrypts production secrets; env pull leaves empty placeholders on disk.
# DATABASE_URL="postgresql://..."
# RECEIVING_WALLET="0x..."
# BSC_RPC_URL="https://bsc-dataseed.binance.org"
# ENABLE_UNIQUE_DEPOSIT_ADDRESSES="true"
# DEPOSIT_MNEMONIC="word1 word2 ... word12"

# Production hardening (H3) — Upstash Redis rate limiting (falls back to in-memory if unset)
# UPSTASH_REDIS_REST_URL=""
# UPSTASH_REDIS_REST_TOKEN=""

# Production hardening (H4) — Pinata IPFS for admin NFT upload
# PINATA_JWT=""

# ─── Treasury deposit sweeper ──────────────────────────────────────────────────
# Hot wallet that funds deposit addresses with BNB for gas and receives swept
# USDT. MUST derive to RECEIVING_WALLET (the sweeper refuses to run otherwise).
# TREASURY_PRIVATE_KEY="0x..."          # never commit a real key
# ENABLE_DEPOSIT_SWEEPER="true"
# Gas is planned dynamically (network price x1.30, limit x1.20) — no hardcoded
# amounts. These tune the funding/retry behaviour; defaults are production-safe:
# SWEEPER_GAS_FUNDING_ATTEMPTS="3"      # verify->top-up->retry rounds before failing
# SWEEPER_MAX_GAS_FUNDING_TXS="5"       # max BNB top-up txs per legacy fund loop
# SWEEPER_TX_CONFIRMATIONS="3"          # confirmations to wait per sweep tx
# SWEEPER_MIN_USDT="0.1"                # below this a deposit is auto-completed, no tx
# SWEEPER_MIN_BNB_REFUND_WEI="10000000000000"  # 0.00001 BNB — below this, skip refund
# SWEEPER_MAX_PER_TICK="2"              # deposits swept per cron tick
# SWEEPER_DRAIN_MAX_MS="270000"         # max wall time for a full drain (Vercel-safe)
