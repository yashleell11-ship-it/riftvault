    "otplib": "^13.4.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sonner": "^2.0.7",
    "viem": "^2.53.1",
    "wagmi": "^3.6.18",
    "zod": "^4.4.3"
  },
  "devDependencies": {
